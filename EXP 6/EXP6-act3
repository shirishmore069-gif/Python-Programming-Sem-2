@author: aarya more
"""

filename = 'student_records.txt'

# Open the file in append mode
with open(filename, 'a') as file:
    more_data = 'y'
    while more_data.lower() == 'y':
        name = input('Enter student name: ')
        roll_no = input('Enter roll number: ')
        marks = input('Enter marks: ')
        
        # Write the student record in the file
        file.write(f'{name},{roll_no},{marks}\n')
        
        more_data = input('Do you want to add another record? (y/n): ')

print('Student records have been appended successfully.')
