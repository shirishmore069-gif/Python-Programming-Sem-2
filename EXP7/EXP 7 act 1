# BankAccount class for deposit and withdrawal.
"""
Created on Mon Apr 27 15:16:05 2026

@author: Aarya
"""

class BankAccount:
    def __init__(self, owner, balance=0.0):
        self.owner = owner
        self.balance = balance

    def deposit(self, amount):
        if amount > 0:
            self.balance += amount
            print(f"Deposited: ${amount:.2f}")
        else:
            print("Deposit amount must be positive.")

    def withdraw(self, amount):
        if 0 < amount <= self.balance:
            self.balance -= amount
            print(f"Withdrawn: ${amount:.2f}")
        elif amount > self.balance:
            print("Insufficient funds!")
        else:
            print("Withdrawal amount must be positive.")

    def display(self):
        print(f"Account Owner: {self.owner}")
        print(f"Current Balance: ${self.balance:.2f}")

# Example Usage
if __name__ == "__main__":
    # Create an account for "Alice" with an initial balance of $100
    account = BankAccount("Alice", 100.0)
    
    account.display()
    account.deposit(50.0)    # Successful deposit
    account.withdraw(30.0)   # Successful withdrawal
    account.withdraw(200.0)  # Failed withdrawal (Insufficient funds)
    account.display()
