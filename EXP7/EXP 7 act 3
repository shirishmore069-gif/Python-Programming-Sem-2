class Student:
    def __init__(self, name, marks):
        self.name = name
        self.marks = marks  # Expects a list of numbers

    def calculate_grade(self):
        # Calculate average by dividing sum of marks by count
        average = sum(self.marks) / len(self.marks)
        
        # Grading logic based on average percentage
        if average >= 90:
            return "A"
        elif average >= 80:
            return "B"
        elif average >= 70:
            return "C"
        elif average >= 60:
            return "D"
        else:
            return "F"

    def display_report(self):
        grade = self.calculate_grade()
        print(f"Student: {self.name}")
        print(f"Average: {sum(self.marks) / len(self.marks):.2f}")
        print(f"Grade: {grade}")

# Creating an instance of Student
student1 = Student("Alex", [85, 92, 78, 90, 88])
student1.display_report()
