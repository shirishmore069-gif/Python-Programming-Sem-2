{"name": "Web Development with Django", "price": 30.00}


def display_books(books):
    """Prints all books and their prices in a formatted way."""
    if not books:
        print("The library is currently empty.")
        return
    print("\nCurrent Library Book Prices:")
    for book in books:
        print(f"- {book['name']}: ${book['price']:.2f}")
    print("-" * 20)

def update_book_price(books, book_name, new_price):
    """
    Updates the price of a specified book.
    If the book is not found, it prints an error message.
    """
    found = False
    for book in books:
        if book['name'].lower() == book_name.lower():
            # Update the price of the existing key in the dictionary
            book['price'] = new_price
            found = True
            print(f"\nSuccessfully updated the price of '{book_name}' to ${new_price:.2f}.")
            break
    if not found:
        print(f"\nError: Book '{book_name}' not found in the library.")
