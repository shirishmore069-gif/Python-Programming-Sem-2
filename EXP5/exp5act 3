# Initial inventory: item name (key) and quantity (value)
inventory = {
    'apples': 50,
    'bananas': 100,
    'oranges': 75
}

def add_stock(item_name, quantity_added):
    """
    Adds new stock for a given item to the inventory dictionary.
    If the item exists, updates its quantity.
    If the item does not exist, adds it as a new entry.
    """
    if item_name in inventory:
        inventory[item_name] += quantity_added
        print(f"Updated stock for '{item_name}'. New quantity: {inventory[item_name]}")
    else:
        inventory[item_name] = quantity_added
        print(f"Added new item '{item_name}' with quantity: {inventory[item_name]}")

def view_inventory():
    """
    Displays the current inventory.
    """
    print("\n--- Current Inventory ---")
    for item, quantity in inventory.items():
        print(f"{item}: {quantity}")
    print("-------------------------\n")

